rules_version = '2';

// Firebase Storage Security Rules for meishavernell-site
//
// NOT CURRENTLY NEEDED. As of this version, nothing on the site uses
// Firebase Storage anymore - the Gallery, Site Photos, and Study Notes
// uploads all go through Cloudinary instead, specifically so you don't
// need Firebase's paid Blaze plan (which Storage now requires just to
// turn on). You can safely ignore the Storage section of the Firebase
// Console. Keeping this file around only in case you ever want to
// re-enable Storage in the future.
//
// >>> Use the SAME admin email you put in firestore.rules <<<

service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return request.auth != null &&
             request.auth.token.email == "youradminemail@example.com";
    }

    // Public site content - anyone can view, only admin can upload/delete.
    match /gallery/{fileName} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /siteMedia/{fileName} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /heroSlides/{fileName} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /portfolioMedia/{fileName} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Member-portal content - only signed-in members can view, only admin
    // can upload/delete.
    match /studyNotes/{fileName} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Deny everything else by default.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
