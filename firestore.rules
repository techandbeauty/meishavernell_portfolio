rules_version = '2';

// Firestore Security Rules for meishavernell-site
// Paste this into: Firebase Console -> Firestore Database -> Rules
//
// Model:
//  - gallery / asvab: public can READ (the site displays these), only a
//    signed-in admin (logged in via admin-dashboard.html) can WRITE.
//  - contacts: public can CREATE (lead-capture forms on asvab-firestore.html)
//    but can never READ, UPDATE, or DELETE - so nobody can pull the list of
//    emails/names or overwrite someone else's entry. Only the signed-in
//    admin can read/manage this list (e.g. from the Firebase console or a
//    future admin view).

service cloud.firestore {
  match /databases/{database}/documents {

    match /gallery/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /asvab/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /contacts/{docId} {
      // Public can submit a new signup (create) or update their own record
      // by hitting the same email-based doc ID (used by the upsert pattern
      // in asvab-firestore.html). No read/list, so nobody can enumerate
      // or scrape the collection.
      allow create, update: if request.resource.data.email is string
                              && request.resource.data.email == docId;
      allow read, delete: if request.auth != null;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
